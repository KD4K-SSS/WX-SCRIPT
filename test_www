#!/bin/bash

OUTPUT_RAW="/tmp/atis_raw.wav"
OUTPUT_FINAL="atis.wav"

# -------------------------
# API CONFIG
# -------------------------
API_KEY="YOUR_WWO_KEY"
LOCATION="33.68,-78.89"

METAR_URL="https://tgftp.nws.noaa.gov/data/observations/metar/stations/KMYR.TXT"
ALERT_URL="https://api.weather.gov/alerts/active?point=${LOCATION}"
WWO_URL="https://api.worldweatheronline.com/premium/v1/weather.ashx?key=${API_KEY}&q=${LOCATION}&format=json&num_of_days=1"

# -------------------------
# FETCH DATA
# -------------------------
METAR=$(curl -s "$METAR_URL" | tail -n 1)
ALERTS=$(curl -s "$ALERT_URL")
JSON=$(curl -s "$WWO_URL")

# -------------------------
# HELPERS
# -------------------------
say_digits() { echo "$1" | sed 's/./& /g'; }
say_number() { echo "$1"; }

capitalize_sentences() {
  echo "$1" | sed -E 's/(^|\. )([a-z])/\1\U\2/g'
}

to_dec() { echo $((10#$1)); }

convert_direction() {
  DEG=$1
  if [ "$DEG" -ge 338 ] || [ "$DEG" -lt 23 ]; then echo "north"
  elif [ "$DEG" -lt 68 ]; then echo "northeast"
  elif [ "$DEG" -lt 113 ]; then echo "east"
  elif [ "$DEG" -lt 158 ]; then echo "southeast"
  elif [ "$DEG" -lt 203 ]; then echo "south"
  elif [ "$DEG" -lt 248 ]; then echo "southwest"
  elif [ "$DEG" -lt 293 ]; then echo "west"
  else echo "northwest"
  fi
}

# -------------------------
# WORLD WEATHER ONLINE FALLBACK
# -------------------------
TEMP_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].temp_F')
DP_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].dewpoint_F')
HUMIDITY_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].humidity')
PRESSURE_MB=$(echo "$JSON" | jq -r '.data.current_condition[0].pressure')
WIND_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].windspeedMiles')
DIR_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].winddirDegree')
VIS_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].visibility')
DESC_WWO=$(echo "$JSON" | jq -r '.data.current_condition[0].weatherDesc[0].value')

# -------------------------
# METAR PARSING (PRIMARY)
# -------------------------
WIND_BLOCK=$(echo "$METAR" | grep -oE '[0-9]{5,6}(G[0-9]{2})?KT' | head -n1)

if [ -n "$WIND_BLOCK" ]; then
  WIND_DIR=${WIND_BLOCK:0:3}
  WIND_SPEED=$((10#${WIND_BLOCK:3:2}))
  WIND_MPH=$(( (WIND_SPEED * 115) / 100 ))
  WIND_DIR_WORD=$(convert_direction "$WIND_DIR")
else
  WIND_MPH=$WIND_WWO
  WIND_DIR_WORD=$(convert_direction "$DIR_WWO")
fi

if [ "$WIND_MPH" -le 2 ]; then
  WIND_PHRASE="wind calm"
else
  WIND_PHRASE="wind from the ${WIND_DIR_WORD} at ${WIND_MPH} miles per hour"
fi

# -------------------------
# VISIBILITY (fallback)
# -------------------------
VIS_RAW=$(echo "$METAR" | grep -oE 'P?M?[0-9/]+SM' | head -n1)

if [ -n "$VIS_RAW" ]; then
  VIS_PHRASE=$(echo "$VIS_RAW" | sed 's/SM/ miles visibility/')
else
  VIS_PHRASE="visibility ${VIS_WWO} miles"
fi

# -------------------------
# TEMP / DEWPOINT (fallback)
# -------------------------
TEMP_DP=$(echo "$METAR" | grep -oE ' M?[0-9]{1,2}/M?[0-9]{1,2}')

if [ -n "$TEMP_DP" ]; then
  TEMP_C=$(echo "$TEMP_DP" | cut -d/ -f1 | tr -d 'M')
  DP_C=$(echo "$TEMP_DP" | cut -d/ -f2 | tr -d 'M')

  TEMP=$(( (TEMP_C * 9 / 5) + 32 ))
  DP=$(( (DP_C * 9 / 5) + 32 ))
else
  TEMP=$TEMP_WWO
  DP=$DP_WWO
fi

# -------------------------
# HUMIDITY / HEAT INDEX
# -------------------------
HUMIDITY=${HUMIDITY_WWO}

HEAT_INDEX=$(awk -v T="$TEMP" -v RH="$HUMIDITY" 'BEGIN{
  if(T >= 80 && RH >= 40){
    HI = -42.379 + 2.04901523*T + 10.14333127*RH \
         - 0.22475541*T*RH - 0.00683783*T*T \
         - 0.05481717*RH*RH + 0.00122874*T*T*RH \
         + 0.00085282*T*RH*RH - 0.00000199*T*T*RH*RH;
    print int(HI+0.5)
  } else {
    print T
  }
}')

# -------------------------
# CLOUDS (hybrid)
# -------------------------
CLOUDS=$(echo "$METAR" | grep -oE '(FEW|SCT|BKN|OVC)[0-9]{3}')

if [ -n "$CLOUDS" ]; then
  CLOUD_PHRASE="based on METAR conditions"
else
  CLOUD_PHRASE="$DESC_WWO"
fi

# -------------------------
# ALTIMETER (fallback)
# -------------------------
ALT=$(echo "$METAR" | grep -oE 'A[0-9]{4}' | tr -d 'A')

if [ -z "$ALT" ]; then
  ALT=$(awk -v mb="$PRESSURE_MB" 'BEGIN { printf "%04d", (mb * 0.02953 * 100) }')
fi

ALT_SPOKEN=$(say_digits "$ALT")

# -------------------------
# ALERTS (SMARTER)
# -------------------------
LIGHTNING_PHRASE="no significant weather hazards"

echo "$ALERTS" | grep -qi "thunderstorm" && LIGHTNING_PHRASE="thunderstorm activity in the area"
echo "$ALERTS" | grep -qi "lightning" && LIGHTNING_PHRASE="lightning detected in the vicinity"
echo "$ALERTS" | grep -qi "tornado" && LIGHTNING_PHRASE="tornado warning in effect"
echo "$ALERTS" | grep -qi "severe" && LIGHTNING_PHRASE="severe weather warning in effect"

# -------------------------
# TIME
# -------------------------
TIME=$(date +"%H%M")
TIME_SPOKEN=$(say_digits "$TIME")

# -------------------------
# FINAL ATIS
# -------------------------
ATIS="Myrtle Beach International Airport information.
Time ${TIME_SPOKEN} local.
${WIND_PHRASE}.
${VIS_PHRASE}.
Sky conditions ${CLOUD_PHRASE}.
Temperature ${TEMP} degrees Fahrenheit. Dewpoint ${DP} degrees Fahrenheit.
Humidity ${HUMIDITY} percent. Heat index ${HEAT_INDEX} degrees Fahrenheit.
Altimeter ${ALT_SPOKEN}.
${LIGHTNING_PHRASE}."

ATIS_FORMATTED=$(capitalize_sentences "$ATIS")
echo "$ATIS_FORMATTED"

# -------------------------
# TTS
# -------------------------
pico2wave -w "$OUTPUT_RAW" "$ATIS_FORMATTED"

sox "$OUTPUT_RAW" "$OUTPUT_FINAL" \
  gain -n -6 \
  pad 0.35 0.35 \
  highpass 70 \
  lowpass 6500 \
  tempo 0.98

aplay "$OUTPUT_FINAL"
